pragma Singleton
import QtQuick

QtObject {
    id: root

    // Generated by `cargo run -p fm-xtask` from seed #6750A4 via matugen
    // (scheme-tonal-spot, dark variant only — this app has no light/dark
    // toggle; the palette is expected to come from an external color file
    // matching the user's shell theme instead, see custom/applyCustomColors
    // below). Do not hand-edit — regenerate instead.

    // Populated by applyCustomColors() from an external JSON color file's
    // contents (e.g. a wallpaper-based Material You generator, matched by
    // role name against this app's own token names) if one was found;
    // stays null otherwise, in which case `scheme` falls back to the
    // generated palette below.
    property var custom: null

    function _customColor(key, fallback) {
        return (root.custom && root.custom[key]) ? root.custom[key] : fallback
    }

    // Parses and applies an external color file's raw JSON text. Reading
    // the file itself happens on the Rust side (FileListModel.
    // readThemeColorsFile()) rather than here via QML's XMLHttpRequest —
    // Qt disables local file reads through XHR by default
    // (QML_XHR_ALLOW_FILE_READ), and requiring users to set an env var
    // just to use a color file isn't reasonable. Safe to call with an
    // empty string (missing file) or invalid JSON — silently leaves
    // `custom` unset so `scheme` keeps using the generated palette. Call
    // once, after FileListModel exists — this is a singleton that may be
    // instantiated before that, so it can't read the file itself from
    // Component.onCompleted here.
    function applyCustomColors(text) {
        if (!text || text.length === 0) {
            return
        }
        try {
            root.custom = JSON.parse(text)
        } catch (e) {
            console.warn("Color.qml: failed to parse custom color file:", e)
        }
    }

    readonly property QtObject palette: QtObject {
        readonly property color primary: "#cfbdfe"
        readonly property color primaryText: "#36275d"
        readonly property color primaryContainer: "#4d3d75"
        readonly property color primaryContainerText: "#e9ddff"
        readonly property color secondary: "#cbc2db"
        readonly property color secondaryText: "#332d41"
        readonly property color secondaryContainer: "#4a4458"
        readonly property color secondaryContainerText: "#e8def8"
        readonly property color tertiary: "#efb8c8"
        readonly property color tertiaryText: "#4a2532"
        readonly property color tertiaryContainer: "#633b48"
        readonly property color tertiaryContainerText: "#ffd9e3"
        readonly property color error: "#ffb4ab"
        readonly property color errorText: "#690005"
        readonly property color errorContainer: "#93000a"
        readonly property color errorContainerText: "#ffdad6"
        readonly property color surface: "#141218"
        readonly property color surfaceText: "#e6e0e9"
        readonly property color surfaceVariantText: "#cac4cf"
        readonly property color surfaceContainerLowest: "#0f0d13"
        readonly property color surfaceContainerLow: "#1d1b20"
        readonly property color surfaceContainer: "#211f24"
        readonly property color surfaceContainerHigh: "#2b292f"
        readonly property color surfaceContainerHighest: "#36343a"
        readonly property color outline: "#948f99"
        readonly property color outlineVariant: "#49454e"
        readonly property color inverseSurface: "#e6e0e9"
        readonly property color inverseOnSurface: "#322f35"
        readonly property color inversePrimary: "#65558f"
    }

    readonly property QtObject customScheme: QtObject {
        readonly property color primary: root._customColor("primary", root.palette.primary)
        readonly property color primaryText: root._customColor("primaryText", root.palette.primaryText)
        readonly property color primaryContainer: root._customColor("primaryContainer", root.palette.primaryContainer)
        readonly property color primaryContainerText: root._customColor("primaryContainerText", root.palette.primaryContainerText)
        readonly property color secondary: root._customColor("secondary", root.palette.secondary)
        readonly property color secondaryText: root._customColor("secondaryText", root.palette.secondaryText)
        readonly property color secondaryContainer: root._customColor("secondaryContainer", root.palette.secondaryContainer)
        readonly property color secondaryContainerText: root._customColor("secondaryContainerText", root.palette.secondaryContainerText)
        readonly property color tertiary: root._customColor("tertiary", root.palette.tertiary)
        readonly property color tertiaryText: root._customColor("tertiaryText", root.palette.tertiaryText)
        readonly property color tertiaryContainer: root._customColor("tertiaryContainer", root.palette.tertiaryContainer)
        readonly property color tertiaryContainerText: root._customColor("tertiaryContainerText", root.palette.tertiaryContainerText)
        readonly property color error: root._customColor("error", root.palette.error)
        readonly property color errorText: root._customColor("errorText", root.palette.errorText)
        readonly property color errorContainer: root._customColor("errorContainer", root.palette.errorContainer)
        readonly property color errorContainerText: root._customColor("errorContainerText", root.palette.errorContainerText)
        readonly property color surface: root._customColor("surface", root.palette.surface)
        readonly property color surfaceText: root._customColor("surfaceText", root.palette.surfaceText)
        readonly property color surfaceVariantText: root._customColor("surfaceVariantText", root.palette.surfaceVariantText)
        readonly property color surfaceContainerLowest: root._customColor("surfaceContainerLowest", root.palette.surfaceContainerLowest)
        readonly property color surfaceContainerLow: root._customColor("surfaceContainerLow", root.palette.surfaceContainerLow)
        readonly property color surfaceContainer: root._customColor("surfaceContainer", root.palette.surfaceContainer)
        readonly property color surfaceContainerHigh: root._customColor("surfaceContainerHigh", root.palette.surfaceContainerHigh)
        readonly property color surfaceContainerHighest: root._customColor("surfaceContainerHighest", root.palette.surfaceContainerHighest)
        readonly property color outline: root._customColor("outline", root.palette.outline)
        readonly property color outlineVariant: root._customColor("outlineVariant", root.palette.outlineVariant)
        readonly property color inverseSurface: root._customColor("inverseSurface", root.palette.inverseSurface)
        readonly property color inverseOnSurface: root._customColor("inverseSurfaceText", root.palette.inverseOnSurface)
        readonly property color inversePrimary: root._customColor("inversePrimary", root.palette.inversePrimary)
    }

    readonly property QtObject scheme: custom !== null ? customScheme : palette
}
